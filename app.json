{
  "expo": {
    "name": "dims",
    "slug": "dims",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dims.png",
    "scheme": "dims",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/dims.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.digimark.dims"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dims.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e593bf30-bcb7-46c0-807b-cbb3404c9a70"
      }
    }
  }
}
